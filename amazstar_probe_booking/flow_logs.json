    "body_snippet": "<div class=\"modal-dialog modal-dialog-scrollable\" role=\"document\">\n    <div class=\"modal-content\">\n        <div class=\"modal-header\">\n            <h4 class=\"modal-title center\">Product Booking</h4>\n            <button type=\"button\" class=\"close\" data-dismiss=\"modal\">&times;</button>\n        </div>\n                    <div class=\"modal-body\">\n                <p class=\"center font-weight-bold\">Are you sure you want to book this product?</p>\n                <p class=\"center\">You must order it within 30 minutes!</p>\n                                <div class=\"form-group center\">\n                    <label for=\"product_id\" style=\"margin-right:20px;\">Product ID </label>\n                    <input class=\"col-md-4 center form-control form-textbox\" readonly=\"\" style=\"display:inline;\" name=\"product_id\" type=\"text\" value=\"65504\" id=\"product_id\">\n                </div>\n            </div>\n            <div class=\"modal-footer\">\n                <button type=\"button\" class=\"center btn btn-default\" data-dismiss=\"modal\">Cancel</button>\n                <button id=\"book_product_submit\" class=\"center btn btn-primary\" type=\"button\">\n                    <span style=\"display:none;\" class=\"spinner-border spinner-border-sm\" role=\"status\" aria-hidden=\"true\"></span>\n                    BOOK\n                </button>\n            </div>\n            </div>\n</div>\n\n<script>\n    async function selectAgain(table_name, order_ids, col_index, col_to_click) {\n        while ($('img#loading_dt_img').parent().attr('style') == 'display: block;') {\n            await sleep(100);\n        }\n\n        col_index = getColumnIndex(col_index);\n        col_to_click = getColumnIndex(col_to_click);\n\n        $(`table#${table_name} > tbody > tr`).each(function(i, e) {\n            let order_id = e.children[col_index].innerText;\n\n            if (order_ids.includes(order_id)) {\n                $(`table#${table_name} > tbody > tr:nth-child(${i+1}) > td:nth-child(${col_to_click+1})`).click();\n            }\n        });\n    }\n\n    function getSelectedIDs(table_name, col) {\n        let selected = $(`table#${table_name} > tbody > tr.selected`).length > 0 ? true : false;\n\n        product_ids = [];\n\n        if (selected) {\n            id_col_index = getColumnIndex(col);\n\n            $(`table#${table_name} > tbody > tr.selected`).each(function(i, e) {\n                let product_id = e.children[id_col_index].innerText;\n\n                product_ids.push(product_id);\n            });\n        }\n\n        return product_ids;\n    "
  },
